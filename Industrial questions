1. Hospital Patient Billing System
Develop a Java program for a hospital billing system using Class and Objects.
Data Members:
• Patient ID 
• Patient Name 
• Room Type (General/Special) 
• Number of Days Admitted 
• Treatment Charges 
Methods:
1. Read patient details. 
2. Calculate room charges based on room type. 
3. Calculate the total hospital bill. 
4. Display patient billing details. 
Note: General Room = ₹1,500/day, Special Room = ₹3,000/day.

import java.util.Scanner;

class Patient {
    // Data Members
    private String patientID;
    private String patientName;
    private String roomType;
    private int numberOfDaysAdmitted;
    private double treatmentCharges;
    
    // Constants for room rates
    private final double GENERAL_ROOM_RATE = 1500.0;
    private final double SPECIAL_ROOM_RATE = 3000.0;

    // Method 1: Read patient details
    public void readPatientDetails() {
        Scanner scanner = new Scanner(System.class);
        System.out.println("--- Enter Patient Details ---");
        System.out.print("Enter Patient ID: ");
        patientID = scanner.nextLine();
        System.out.print("Enter Patient Name: ");
        patientName = scanner.nextLine();
        
        while (true) {
            System.out.print("Enter Room Type (General/Special): ");
            roomType = scanner.nextLine().trim();
            if (roomType.equalsIgnoreCase("General") || roomType.equalsIgnoreCase("Special")) {
                break;
            }
            System.out.println("Invalid room type! Please enter either 'General' or 'Special'.");
        }
        
        System.out.print("Enter Number of Days Admitted: ");
        numberOfDaysAdmitted = scanner.nextInt();
        System.out.print("Enter Treatment Charges: ");
        treatmentCharges = scanner.nextDouble();
    }

    // Method 2: Calculate room charges based on room type
    public double calculateRoomCharges() {
        if (roomType.equalsIgnoreCase("General")) {
            return numberOfDaysAdmitted * GENERAL_ROOM_RATE;
        } else {
            return numberOfDaysAdmitted * SPECIAL_ROOM_RATE;
        }
    }

    // Method 3: Calculate the total hospital bill
    public double calculateTotalBill() {
        return calculateRoomCharges() + treatmentCharges;
    }

    // Method 4: Display patient billing details
    public void displayBillingDetails() {
        System.out.println("\n=================================");
        System.out.println("     PATIENT BILLING DETAILS     ");
        System.out.println("=================================");
        System.out.println("Patient ID:             " + patientID);
        System.out.println("Patient Name:           " + patientName);
        System.out.println("Room Type:              " + roomType);
        System.out.println("Days Admitted:          " + numberOfDaysAdmitted);
        System.out.printf("Room Charges:           %.2f\n", calculateRoomCharges());
        System.out.printf("Treatment Charges:      %.2f\n", treatmentCharges);
        System.out.println("---------------------------------");
        System.out.printf("TOTAL HOSPITAL BILL:    %.2f\n", calculateTotalBill());
        System.out.println("=================================");
    }
}

public class HospitalBillingSystem {
    public static void main(String[] args) {
        Patient patient = new Patient();
        patient.readPatientDetails();
        patient.displayBillingDetails();

    }
}

2. Airline Ticket Reservation System
Develop a Java program for an airline reservation system using Class and Objects.
Data Members:
• Passenger ID 
• Passenger Name 
• Flight Number 
• Ticket Fare 
• Number of Tickets 
Methods:
1. Read passenger details. 
2. Calculate total ticket cost. 
3. Apply a 5% discount if more than 5 tickets are booked. 
4. Display booking and payment details. 
Note: GST = 12% on the final amount

import java.util.Scanner;

class Passenger {
    // Data Members
    private String passengerID;
    private String passengerName;
    private String flightNumber;
    private double ticketFare;
    private int numberOfTickets;

    // Method 1: Read passenger details
    public void readPassengerDetails() {
        Scanner scanner = new Scanner(System.class);
        System.out.println("--- Enter Passenger Details ---");
        System.out.print("Enter Passenger ID: ");
        passengerID = scanner.nextLine();
        System.out.print("Enter Passenger Name: ");
        passengerName = scanner.nextLine();
        System.out.print("Enter Flight Number: ");
        flightNumber = scanner.nextLine();
        System.out.print("Enter Ticket Fare per Person: ");
        ticketFare = scanner.nextDouble();
        System.out.print("Enter Number of Tickets to Book: ");
        numberOfTickets = scanner.nextInt();
    }

    // Method 2 & 3: Calculate total ticket cost with potential discount and GST
    public double calculateTotalCost() {
        double subtotal = ticketFare * numberOfTickets;
        
        // Apply a 5% discount if more than 5 tickets are booked
        if (numberOfTickets > 5) {
            subtotal = subtotal * 0.95; 
        }
        
        // Apply 12% GST on the final amount
        double finalAmount = subtotal * 1.12; 
        return finalAmount;
    }

    // Method 4: Display booking and payment details
    public void displayBookingDetails() {
        double baseCost = ticketFare * numberOfTickets;
        double discount = (numberOfTickets > 5) ? (baseCost * 0.05) : 0.0;
        double discountedSubtotal = baseCost - discount;
        double gstAmount = discountedSubtotal * 0.12;

        System.out.println("\n=================================");
        System.out.println("    AIRLINE BOOKING DETAILS      ");
        System.out.println("=================================");
        System.out.println("Passenger ID:         " + passengerID);
        System.out.println("Passenger Name:       " + passengerName);
        System.out.println("Flight Number:        " + flightNumber);
        System.out.println("Number of Tickets:    " + numberOfTickets);
        System.out.printf("Base Fare Subtotal:   %.2f\n", baseCost);
        System.out.printf("Discount Applied:    -%.2f\n", discount);
        System.out.printf("GST Amount (12%%):    +%.2f\n", gstAmount);
        System.out.println("---------------------------------");
        System.out.printf("FINAL AMOUNT PAYABLE: %.2f\n", calculateTotalCost());
        System.out.println("=================================");
    }
}

public class AirlineReservationSystem {
    public static void main(String[] args) {
        Passenger passenger = new Passenger();
        passenger.readPassengerDetails();
        passenger.displayBookingDetails();
    }
}
3. Vehicle Rental Management System
Develop a Java program for a vehicle rental company using Class and Objects.
Data Members:
• Customer ID 
• Customer Name 
• Vehicle Type (Car/Bike) 
• Number of Rental Days 
Methods:
1. Read customer details. 
2. Calculate rental charges. 
3. Add a late return penalty if applicable. 
4. Display the final rental bill. 
Note: Car = ₹2,000/day, Bike = ₹500/day.


import java.util.Scanner;

class VehicleRental {
    // Data Members
    private String customerID;
    private String customerName;
    private String vehicleType;
    private int numberOfRentalDays;
    private double lateReturnPenalty;

    // Constants for rental rates
    private final double CAR_RATE_PER_DAY = 2000.0;
    private final double BIKE_RATE_PER_DAY = 500.0;

    // Method 1: Read customer details
    public void readCustomerDetails() {
        Scanner scanner = new Scanner(System.class);
        System.out.println("--- Enter Vehicle Rental Details ---");
        System.out.print("Enter Customer ID: ");
        customerID = scanner.nextLine();
        System.out.print("Enter Customer Name: ");
        customerName = scanner.nextLine();
        
        while (true) {
            System.out.print("Enter Vehicle Type (Car/Bike): ");
            vehicleType = scanner.nextLine().trim();
            if (vehicleType.equalsIgnoreCase("Car") || vehicleType.equalsIgnoreCase("Bike")) {
                break;
            }
            System.out.println("Invalid vehicle type! Please enter either 'Car' or 'Bike'.");
        }
        
        System.out.print("Enter Number of Rental Days: ");
        numberOfRentalDays = scanner.nextInt();
        
        // Method 3: Add a late return penalty if applicable
        System.out.print("Is there a late return penalty? Enter amount (0 if none): ");
        lateReturnPenalty = scanner.nextDouble();
    }

    // Method 2: Calculate rental charges
    public double calculateRentalCharges() {
        if (vehicleType.equalsIgnoreCase("Car")) {
            return numberOfRentalDays * CAR_RATE_PER_DAY;
        } else {
            return numberOfRentalDays * BIKE_RATE_PER_DAY;
        }
    }

    // Method 4: Display the final rental bill
    public void displayRentalBill() {
        double rentalCharges = calculateRentalCharges();
        double finalBill = rentalCharges + lateReturnPenalty;

        System.out.println("\n=================================");
        System.out.println("       FINAL RENTAL BILL         ");
        System.out.println("=================================");
        System.out.println("Customer ID:        " + customerID);
        System.out.println("Customer Name:      " + customerName);
        System.out.println("Vehicle Type:       " + vehicleType);
        System.out.println("Rental Duration:    " + numberOfRentalDays + " Days");
        System.out.printf("Base Rental Cost:   %.2f\n", rentalCharges);
        System.out.printf("Late Penalty Fees:  %.2f\n", lateReturnPenalty);
        System.out.println("---------------------------------");
        System.out.printf("TOTAL RENTAL BILL:  %.2f\n", finalBill);
        System.out.println("=================================");
    }
}

public class VehicleRentalManagementSystem {
    public static void main(String[] args) {
        VehicleRental rental = new VehicleRental();
        rental.readCustomerDetails();
        rental.displayRentalBill();
    }
}


4. Manufacturing Production Monitoring System
Develop a Java program to monitor daily production in a manufacturing company 
using Class and Objects.Data Members:
• Product ID 
• Product Name 
• Target Quantity 
• Produced Quantity 
Methods:
1. Read product details. 
2. Compare actual production with the target. 
3. Calculate production efficiency percentage. 
4. Display production status (Achieved/Not Achieved). 
Note: Efficiency = (Produced Quantity / Target Quantity) × 100.


import java.util.Scanner;

class ProductionMonitor {
    // Data Members
    private String productID;
    private String productName;
    private double targetQuantity;
    private double producedQuantity;

    // Method 1: Read product details
    public void readProductDetails() {
        Scanner scanner = new Scanner(System.class);
        System.out.println("--- Enter Production Statistics ---");
        System.out.print("Enter Product ID: ");
        productID = scanner.nextLine();
        System.out.print("Enter Product Name: ");
        productName = scanner.nextLine();
        System.out.print("Enter Target Quantity: ");
        targetQuantity = scanner.nextDouble();
        System.out.print("Enter Actual Produced Quantity: ");
        producedQuantity = scanner.nextDouble();
    }

    // Method 3: Calculate production efficiency percentage
    public double calculateEfficiencyPercentage() {
        if (targetQuantity == 0) return 0; // Safeguard against division by zero
        return (producedQuantity / targetQuantity) * 100;
    }

    // Method 2 & 4: Compare actual production with target & Display status
    public void displayProductionStatus() {
        double efficiency = calculateEfficiencyPercentage();
        String status;

        // Compare actual production with target
        if (producedQuantity >= targetQuantity) {
            status = "Achieved";
        } else {
            status = "Not Achieved";
        }

        System.out.println("\n=================================");
        System.out.println("   PRODUCTION MONITORING STATUS  ");
        System.out.println("=================================");
        System.out.println("Product ID:          " + productID);
        System.out.println("Product Name:        " + productName);
        System.out.println("Target Quantity:     " + targetQuantity);
        System.out.println("Produced Quantity:   " + producedQuantity);
        System.out.printf("Production Efficiency: %.2f%%\n", efficiency);
        System.out.println("---------------------------------");
        System.out.println("STATUS DECLARED:     " + status);
        System.out.println("=================================");
    }
}

public class ManufacturingProductionSystem {
    public static void main(String[] args) {
        ProductionMonitor monitor = new ProductionMonitor();
        monitor.readProductDetails();
        monitor.displayProductionStatus();
    }
}

5. Online Course Enrollment System
Develop a Java program for an online learning platform using Class and Objects.
Data Members:
• Student ID 
• Student Name 
• Course Name 
• Course Fee 
Methods:
1. Read student and course details. 
2. Calculate the payable amount. 
3. Provide a 15% scholarship discount if the fee exceeds ₹20,000. 
4. Display enrollment and payment details. 
Note: Registration fee = ₹500.


import java.util.Scanner;

class CourseEnrollment {
    // Data Members
    private String studentID;
    private String studentName;
    private String courseName;
    private double courseFee;
    
    // Constant
    private final double REGISTRATION_FEE = 500.0;

    // Method 1: Read student and course details
    public void readEnrollmentDetails() {
        Scanner scanner = new Scanner(System.class);
        System.out.println("--- Enter Course Enrollment Details ---");
        System.out.print("Enter Student ID: ");
        studentID = scanner.nextLine();
        System.out.print("Enter Student Name: ");
        studentName = scanner.nextLine();
        System.out.print("Enter Course Name: ");
        courseName = scanner.nextLine();
        System.out.print("Enter Course Fee: ");
        courseFee = scanner.nextDouble();
    }

    // Method 2 & 3: Calculate payable amount and check scholarship parameters
    public double calculatePayableAmount() {
        double finalCourseFee = courseFee;

        // Provide a 15% scholarship discount if the fee exceeds 20,000
        if (courseFee > 20000) {
            finalCourseFee = courseFee * 0.85; 
        }

        // Total payable amount includes the course fee and the baseline registration fee
        return finalCourseFee + REGISTRATION_FEE;
    }

    // Method 4: Display enrollment and payment details
    public void displayEnrollmentDetails() {
        double discount = (courseFee > 20000) ? (courseFee * 0.15) : 0.0;
        double netCourseFee = courseFee - discount;

        System.out.println("\n=================================");
        System.out.println("   ENROLLMENT & PAYMENT RECEIPT  ");
        System.out.println("=================================");
        System.out.println("Student ID:             " + studentID);
        System.out.println("Student Name:           " + studentName);
        System.out.println("Enrolled Course:        " + courseName);
        System.out.printf("Base Course Fee:        %.2f\n", courseFee);
        System.out.printf("Scholarship (15%% Off):  -%.2f\n", discount);
        System.out.printf("Registration Fixed Fee: +%.2f\n", REGISTRATION_FEE);
        System.out.println("---------------------------------");
        System.out.printf("TOTAL PAYABLE AMOUNT:   %.2f\n", calculatePayableAmount());
        System.out.println("=================================");
    }
}

public class OnlineCourseEnrollmentSystem {
    public static void main(String[] args) {
        CourseEnrollment enrollment = new CourseEnrollment();
        enrollment.readEnrollmentDetails();
        enrollment.displayEnrollmentDetails();
    }
}



